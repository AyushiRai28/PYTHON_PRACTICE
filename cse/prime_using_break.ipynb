    "flag =  0\n",
    "i =2\n",
    "while i<n/2:\n",
    "    if n%i==0:\n",
    "        flag=1\n",
    "        break\n",
    "    i=i+1\n",
    "if(flag==0):\n",
    "    print(\"prime\")\n",
    "else:\n",
    "    print(\"not prime\")"
